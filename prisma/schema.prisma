generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum RoleScope {
  PLATFORM
  ORGANIZATION
  WORKSPACE
  TEAM
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum CommunicationObjectiveType {
  AWARENESS
  RECRUITMENT
  LEAD_GENERATION
  EMPLOYER_BRAND
  EXPERTISE
  TRAFFIC
  INSTITUTIONAL
}

enum BrandFormalityLevel {
  CASUAL
  BALANCED
  FORMAL
}

enum EmojiUsage {
  NONE
  LIGHT
  MODERATE
}

enum ContentType {
  SOCIAL_POST
}

enum ContentPlatform {
  LINKEDIN
}

enum ContentStatus {
  DRAFT
  READY_FOR_REVIEW
  CHANGES_REQUESTED
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum NotificationType {
  CONTENT_ASSIGNED
  REVIEW_REQUESTED
  CONTENT_APPROVED
  CHANGES_REQUESTED
  COMMENT_ADDED
  CONTENT_SCHEDULED
}

enum ContentVariantStyle {
  DIRECT_CONCISE
  EXPERT_EDUCATIONAL
  HUMAN_ENGAGING
}

enum AiGenerationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DirectorAnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum DirectorAnalysisTrigger {
  MANUAL
  DAILY
  EVENT
}

enum DirectorRecommendationType {
  EDITORIAL_GAP
  CAMPAIGN_GAP
  OBJECTIVE_IMBALANCE
  CADENCE_WARNING
  WORKFLOW_BLOCKER
  BRAND_PROFILE_INCOMPLETE
  CONTENT_OPPORTUNITY
  CALENDAR_SUGGESTION
}

enum DirectorRecommendationStatus {
  NEW
  VIEWED
  ACCEPTED
  DISMISSED
  COMPLETED
  EXPIRED
}

enum DirectorRecommendationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RecommendationFeedbackValue {
  HELPFUL
  NOT_HELPFUL
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  supabaseAuthId String   @unique @map("supabase_auth_id") @db.Uuid
  email          String   @unique
  fullName       String   @default("") @map("full_name")
  avatarPath     String?  @map("avatar_path")
  locale         String   @default("fr-FR")
  timezone       String   @default("Europe/Paris")
  onboardingDone Boolean  @default(false) @map("onboarding_done")
  platformRoleId String?  @map("platform_role_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  platformRole             Role?                    @relation("PlatformRole", fields: [platformRoleId], references: [id], onDelete: SetNull)
  organizationMemberships  OrganizationMembership[]
  workspaceMemberships     WorkspaceMembership[]
  teamMemberships          TeamMembership[]
  createdOrganizations     Organization[]           @relation("OrganizationCreator")
  sentInvitations          Invitation[]             @relation("InvitationSender")
  auditLogs                AuditLog[]
  onboardingProgress       OnboardingProgress?
  contentItems             ContentItem[]
  assignedContentItems     ContentItem[]            @relation("ContentAssignee")
  reviewedContentItems     ContentItem[]            @relation("ContentReviewer")
  approvedContentItems     ContentItem[]            @relation("ContentApprover")
  campaigns                Campaign[]               @relation("CampaignCreator")
  contentComments          ContentComment[]
  receivedNotifications    Notification[]           @relation("NotificationRecipient")
  sentNotifications        Notification[]           @relation("NotificationActor")
  aiGenerations            AiGeneration[]
  directorAnalyses         DirectorAnalysis[]       @relation("DirectorAnalysisTriggerUser")
  actedRecommendations     DirectorRecommendation[] @relation("DirectorRecommendationActor")
  dismissedRecommendations DirectorRecommendation[] @relation("DirectorRecommendationDismissedBy")
  recommendationFeedback   RecommendationFeedback[]

  @@index([platformRoleId])
  @@map("users")
}

model Organization {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String
  slug                String    @unique
  logoPath            String?   @map("logo_path")
  websiteUrl          String?   @map("website_url")
  industry            String?
  description         String?
  mission             String?
  values              String[]  @default([])
  brandColors         Json      @default("{}") @map("brand_colors")
  communicationTone   String?   @map("communication_tone")
  forbiddenWords      String[]  @default([]) @map("forbidden_words")
  favoriteExpressions String[]  @default([]) @map("favorite_expressions")
  countryCode         String?   @map("country_code")
  primaryLanguage     String    @default("fr") @map("primary_language")
  createdById         String    @map("created_by_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt          DateTime? @map("archived_at") @db.Timestamptz(3)

  createdBy               User                          @relation("OrganizationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  workspaces              Workspace[]
  memberships             OrganizationMembership[]
  customRoles             Role[]                        @relation("OrganizationRoles")
  invitations             Invitation[]
  auditLogs               AuditLog[]
  billingAccount          BillingAccount?
  featureFlagOverrides    OrganizationFeatureOverride[]
  outboxEvents            OutboxEvent[]
  completedOnboardings    OnboardingProgress[]          @relation("CompletedOnboardingOrganization")
  brandProfiles           BrandProfile[]
  communicationObjectives CommunicationObjective[]
  contentItems            ContentItem[]
  contentVariants         ContentVariant[]
  aiGenerations           AiGeneration[]
  campaigns               Campaign[]
  contentComments         ContentComment[]
  notifications           Notification[]
  directorAnalyses        DirectorAnalysis[]
  directorRecommendations DirectorRecommendation[]
  directorPreferences     DirectorPreference[]
  recommendationFeedback  RecommendationFeedback[]

  @@index([createdById])
  @@map("organizations")
}

model Workspace {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  slug           String
  description    String?
  isDefault      Boolean   @default(false) @map("is_default")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt     DateTime? @map("archived_at") @db.Timestamptz(3)

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams                   Team[]
  memberships             WorkspaceMembership[]
  invitations             Invitation[]
  brandProfile            BrandProfile?
  communicationObjectives CommunicationObjective[]
  contentItems            ContentItem[]
  contentVariants         ContentVariant[]
  aiGenerations           AiGeneration[]
  campaigns               Campaign[]
  contentComments         ContentComment[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  directorAnalyses        DirectorAnalysis[]
  directorRecommendations DirectorRecommendation[]
  directorPreference      DirectorPreference?
  recommendationFeedback  RecommendationFeedback[]

  @@unique([organizationId, slug])
  @@index([organizationId, archivedAt])
  @@map("workspaces")
}

model Team {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  name        String
  slug        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz(3)

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships TeamMembership[]
  invitations Invitation[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, archivedAt])
  @@map("teams")
}

model Role {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  systemKey      String?   @unique @map("system_key")
  key            String
  name           String
  description    String?
  scope          RoleScope
  isSystem       Boolean   @default(false) @map("is_system")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization            Organization?            @relation("OrganizationRoles", fields: [organizationId], references: [id], onDelete: Cascade)
  permissions             RolePermission[]
  platformUsers           User[]                   @relation("PlatformRole")
  organizationMemberships OrganizationMembership[]
  workspaceMemberships    WorkspaceMembership[]
  teamMemberships         TeamMembership[]
  invitations             Invitation[]

  @@unique([organizationId, key, scope])
  @@index([key, scope, isSystem])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  resource    String
  action      String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  roles RolePermission[]

  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model OrganizationMembership {
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  roleId         String           @map("role_id") @db.Uuid
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime?        @map("joined_at") @db.Timestamptz(3)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, roleId, status])
  @@map("organization_memberships")
}

model WorkspaceMembership {
  workspaceId String           @map("workspace_id") @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  roleId      String           @map("role_id") @db.Uuid
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([workspaceId, userId])
  @@index([userId, status])
  @@index([workspaceId, roleId, status])
  @@map("workspace_memberships")
}

model TeamMembership {
  teamId    String           @map("team_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  roleId    String           @map("role_id") @db.Uuid
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([teamId, userId])
  @@index([userId, status])
  @@index([teamId, roleId, status])
  @@map("team_memberships")
}

model Invitation {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  workspaceId    String?   @map("workspace_id") @db.Uuid
  teamId         String?   @map("team_id") @db.Uuid
  roleId         String    @map("role_id") @db.Uuid
  email          String
  tokenHash      String    @unique @map("token_hash")
  invitedById    String    @map("invited_by_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(3)
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy    User         @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Restrict)

  @@unique([organizationId, email])
  @@index([email, expiresAt])
  @@index([workspaceId])
  @@index([teamId])
  @@map("invitations")
}

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  features        PlanFeature[]
  billingAccounts BillingAccount[]

  @@map("plans")
}

model FeatureFlag {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique
  name           String
  description    String?
  defaultEnabled Boolean  @default(false) @map("default_enabled")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  plans                 PlanFeature[]
  organizationOverrides OrganizationFeatureOverride[]

  @@map("feature_flags")
}

model PlanFeature {
  planId        String  @map("plan_id") @db.Uuid
  featureFlagId String  @map("feature_flag_id") @db.Uuid
  enabled       Boolean @default(true)
  configuration Json?

  plan        Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureFlag FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

  @@id([planId, featureFlagId])
  @@map("plan_features")
}

model OrganizationFeatureOverride {
  organizationId String    @map("organization_id") @db.Uuid
  featureFlagId  String    @map("feature_flag_id") @db.Uuid
  enabled        Boolean
  configuration  Json?
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureFlag  FeatureFlag  @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

  @@id([organizationId, featureFlagId])
  @@index([expiresAt])
  @@map("organization_feature_overrides")
}

model BillingAccount {
  id                   String             @id @default(uuid()) @db.Uuid
  organizationId       String             @unique @map("organization_id") @db.Uuid
  planId               String?            @map("plan_id") @db.Uuid
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz(3)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan?        @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([planId])
  @@map("billing_accounts")
}

model OutboxEvent {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String?           @map("organization_id") @db.Uuid
  type           String
  aggregateType  String            @map("aggregate_type")
  aggregateId    String            @map("aggregate_id")
  payload        Json
  metadata       Json              @default("{}")
  status         OutboxEventStatus @default(PENDING)
  attempts       Int               @default(0)
  availableAt    DateTime          @default(now()) @map("available_at") @db.Timestamptz(3)
  publishedAt    DateTime?         @map("published_at") @db.Timestamptz(3)
  lastError      String?           @map("last_error")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

model AuditLog {
  id             BigInt   @id @default(autoincrement())
  organizationId String   @map("organization_id") @db.Uuid
  actorId        String?  @map("actor_id") @db.Uuid
  workspaceId    String?  @map("workspace_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([organizationId, workspaceId, entityType, entityId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model OnboardingProgress {
  userId                  String    @id @map("user_id") @db.Uuid
  currentStep             Int       @default(1) @map("current_step")
  draft                   Json      @default("{}")
  completedAt             DateTime? @map("completed_at") @db.Timestamptz(3)
  completedOrganizationId String?   @unique @map("completed_organization_id") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedOrganization Organization? @relation("CompletedOnboardingOrganization", fields: [completedOrganizationId], references: [id], onDelete: SetNull)

  @@map("onboarding_progress")
}

model BrandProfile {
  id               String              @id @default(uuid()) @db.Uuid
  organizationId   String              @map("organization_id") @db.Uuid
  workspaceId      String              @unique @map("workspace_id") @db.Uuid
  productsServices String[]            @default([]) @map("products_services")
  targetAudiences  String[]            @default([]) @map("target_audiences")
  formalityLevel   BrandFormalityLevel @default(BALANCED) @map("formality_level")
  emojiUsage       EmojiUsage          @default(LIGHT) @map("emoji_usage")
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("brand_profiles")
}

model CommunicationObjective {
  id             String                     @id @default(uuid()) @db.Uuid
  organizationId String                     @map("organization_id") @db.Uuid
  workspaceId    String                     @map("workspace_id") @db.Uuid
  type           CommunicationObjectiveType
  isPrimary      Boolean                    @default(false) @map("is_primary")
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type])
  @@index([organizationId])
  @@map("communication_objectives")
}

model AiGeneration {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  workspaceId    String             @map("workspace_id") @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  provider       String
  model          String
  agentType      String             @map("agent_type")
  contentType    ContentType        @default(SOCIAL_POST) @map("content_type")
  status         AiGenerationStatus @default(PENDING)
  inputTokens    Int                @default(0) @map("input_tokens")
  outputTokens   Int                @default(0) @map("output_tokens")
  totalTokens    Int                @default(0) @map("total_tokens")
  durationMs     Int?               @map("duration_ms")
  estimatedCost  Decimal?           @map("estimated_cost") @db.Decimal(12, 6)
  currency       String             @default("USD")
  request        Json               @default("{}")
  errorCode      String?            @map("error_code")
  errorMessage   String?            @map("error_message")
  startedAt      DateTime           @default(now()) @map("started_at") @db.Timestamptz(3)
  completedAt    DateTime?          @map("completed_at") @db.Timestamptz(3)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  variants     ContentVariant[]

  @@index([organizationId, workspaceId, createdAt(sort: Desc)])
  @@index([userId, status])
  @@map("ai_generations")
}

model ContentVariant {
  id             String              @id @default(uuid()) @db.Uuid
  generationId   String              @map("generation_id") @db.Uuid
  organizationId String              @map("organization_id") @db.Uuid
  workspaceId    String              @map("workspace_id") @db.Uuid
  style          ContentVariantStyle
  angle          String
  hook           String
  body           String
  cta            String
  hashtags       String[]            @default([])
  rationale      String
  confidence     Decimal             @db.Decimal(3, 2)
  warnings       String[]            @default([])
  position       Int
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)

  generation          AiGeneration  @relation(fields: [generationId], references: [id], onDelete: Cascade)
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace           Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourcedContentItems ContentItem[]

  @@unique([generationId, position])
  @@index([organizationId, workspaceId])
  @@map("content_variants")
}

model ContentItem {
  id                  String                      @id @default(uuid()) @db.Uuid
  organizationId      String                      @map("organization_id") @db.Uuid
  workspaceId         String                      @map("workspace_id") @db.Uuid
  authorId            String                      @map("author_id") @db.Uuid
  sourceVariantId     String?                     @map("source_variant_id") @db.Uuid
  type                ContentType                 @default(SOCIAL_POST)
  platform            ContentPlatform             @default(LINKEDIN)
  title               String
  body                String
  cta                 String?
  hashtags            String[]                    @default([])
  status              ContentStatus               @default(DRAFT)
  objective           CommunicationObjectiveType?
  tone                String?
  targetAudience      String?                     @map("target_audience")
  scheduledAt         DateTime?                   @map("scheduled_at") @db.Timestamptz(3)
  publishedAt         DateTime?                   @map("published_at") @db.Timestamptz(3)
  timezone            String                      @default("Europe/Paris")
  approvalRequestedAt DateTime?                   @map("approval_requested_at") @db.Timestamptz(3)
  approvedAt          DateTime?                   @map("approved_at") @db.Timestamptz(3)
  approvedById        String?                     @map("approved_by_id") @db.Uuid
  assigneeId          String?                     @map("assignee_id") @db.Uuid
  reviewerId          String?                     @map("reviewer_id") @db.Uuid
  campaignId          String?                     @map("campaign_id") @db.Uuid
  createdAt           DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt          DateTime?                   @map("archived_at") @db.Timestamptz(3)

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace               Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author                  User                     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  sourceVariant           ContentVariant?          @relation(fields: [sourceVariantId], references: [id], onDelete: SetNull)
  approvedBy              User?                    @relation("ContentApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  assignee                User?                    @relation("ContentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reviewer                User?                    @relation("ContentReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  campaign                Campaign?                @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  comments                ContentComment[]
  notifications           Notification[]
  directorRecommendations DirectorRecommendation[]

  @@index([organizationId, workspaceId, status, updatedAt(sort: Desc)])
  @@index([authorId])
  @@index([sourceVariantId])
  @@index([organizationId, workspaceId, scheduledAt])
  @@index([organizationId, workspaceId, status, scheduledAt])
  @@index([organizationId, workspaceId, campaignId, scheduledAt])
  @@index([assigneeId, status])
  @@index([reviewerId, status])
  @@map("content_items")
}

model Campaign {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  workspaceId    String         @map("workspace_id") @db.Uuid
  createdById    String         @map("created_by_id") @db.Uuid
  name           String
  description    String?
  objective      String?
  startDate      DateTime?      @map("start_date") @db.Date
  endDate        DateTime?      @map("end_date") @db.Date
  status         CampaignStatus @default(DRAFT)
  color          String         @default("#8B5CF6")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  archivedAt     DateTime?      @map("archived_at") @db.Timestamptz(3)

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace               Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy               User                     @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: Restrict)
  contentItems            ContentItem[]
  directorRecommendations DirectorRecommendation[]

  @@index([organizationId, workspaceId, status, startDate])
  @@index([createdById])
  @@map("campaigns")
}

model ContentComment {
  id               String    @id @default(uuid()) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  workspaceId      String    @map("workspace_id") @db.Uuid
  contentId        String    @map("content_id") @db.Uuid
  authorId         String    @map("author_id") @db.Uuid
  body             String
  mentionedUserIds String[]  @default([]) @map("mentioned_user_ids") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content      ContentItem  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([organizationId, workspaceId, contentId, createdAt])
  @@index([authorId])
  @@map("content_comments")
}

model Notification {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  workspaceId    String           @map("workspace_id") @db.Uuid
  recipientId    String           @map("recipient_id") @db.Uuid
  actorId        String?          @map("actor_id") @db.Uuid
  contentId      String?          @map("content_id") @db.Uuid
  type           NotificationType
  payload        Json             @default("{}")
  readAt         DateTime?        @map("read_at") @db.Timestamptz(3)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipient    User         @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor        User?        @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  content      ContentItem? @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([recipientId, organizationId, workspaceId, readAt, createdAt(sort: Desc)])
  @@index([contentId])
  @@map("notifications")
}

model DirectorAnalysis {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @map("organization_id") @db.Uuid
  workspaceId    String                  @map("workspace_id") @db.Uuid
  triggeredById  String?                 @map("triggered_by_id") @db.Uuid
  triggerType    DirectorAnalysisTrigger @map("trigger_type")
  provider       String
  model          String
  status         DirectorAnalysisStatus  @default(PENDING)
  periodStart    DateTime                @map("period_start") @db.Timestamptz(3)
  periodEnd      DateTime                @map("period_end") @db.Timestamptz(3)
  inputSummary   Json                    @default("{}") @map("input_summary")
  facts          Json                    @default("{}")
  startedAt      DateTime?               @map("started_at") @db.Timestamptz(3)
  completedAt    DateTime?               @map("completed_at") @db.Timestamptz(3)
  errorCode      String?                 @map("error_code")
  errorMessage   String?                 @map("error_message")
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace       Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  triggeredBy     User?                    @relation("DirectorAnalysisTriggerUser", fields: [triggeredById], references: [id], onDelete: SetNull)
  recommendations DirectorRecommendation[]

  @@index([organizationId, workspaceId, createdAt(sort: Desc)])
  @@index([organizationId, workspaceId, status])
  @@index([triggeredById])
  @@map("director_analyses")
}

model DirectorRecommendation {
  id               String                         @id @default(uuid()) @db.Uuid
  organizationId   String                         @map("organization_id") @db.Uuid
  workspaceId      String                         @map("workspace_id") @db.Uuid
  analysisId       String                         @map("analysis_id") @db.Uuid
  type             DirectorRecommendationType
  status           DirectorRecommendationStatus   @default(NEW)
  priority         DirectorRecommendationPriority @default(MEDIUM)
  confidence       Decimal                        @db.Decimal(3, 2)
  title            String
  summary          String
  rationale        String
  suggestedAction  Json                           @default("{}") @map("suggested_action")
  evidence         Json                           @default("{}")
  campaignId       String?                        @map("campaign_id") @db.Uuid
  contentId        String?                        @map("content_id") @db.Uuid
  objectiveType    CommunicationObjectiveType?    @map("objective_type")
  suggestedAt      DateTime?                      @map("suggested_at") @db.Timestamptz(3)
  expiresAt        DateTime?                      @map("expires_at") @db.Timestamptz(3)
  actedAt          DateTime?                      @map("acted_at") @db.Timestamptz(3)
  actedById        String?                        @map("acted_by_id") @db.Uuid
  dismissedAt      DateTime?                      @map("dismissed_at") @db.Timestamptz(3)
  dismissedById    String?                        @map("dismissed_by_id") @db.Uuid
  dismissalReason  String?                        @map("dismissal_reason")
  deduplicationKey String                         @map("deduplication_key")
  createdAt        DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  analysis     DirectorAnalysis         @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  campaign     Campaign?                @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  content      ContentItem?             @relation(fields: [contentId], references: [id], onDelete: SetNull)
  actedBy      User?                    @relation("DirectorRecommendationActor", fields: [actedById], references: [id], onDelete: SetNull)
  dismissedBy  User?                    @relation("DirectorRecommendationDismissedBy", fields: [dismissedById], references: [id], onDelete: SetNull)
  feedback     RecommendationFeedback[]

  @@unique([organizationId, workspaceId, deduplicationKey])
  @@index([organizationId, workspaceId, status, priority, createdAt(sort: Desc)])
  @@index([analysisId])
  @@index([campaignId])
  @@index([contentId])
  @@index([expiresAt])
  @@map("director_recommendations")
}

model DirectorPreference {
  id                          String                       @id @default(uuid()) @db.Uuid
  organizationId              String                       @map("organization_id") @db.Uuid
  workspaceId                 String                       @unique @map("workspace_id") @db.Uuid
  desiredWeeklyFrequency      Int                          @default(3) @map("desired_weekly_frequency")
  preferredWeekdays           Int[]                        @default([1, 2, 3, 4, 5]) @map("preferred_weekdays")
  preferredHours              String[]                     @default(["09:00"]) @map("preferred_hours")
  silenceThresholdDays        Int                          @default(7) @map("silence_threshold_days")
  maxDailyRecommendations     Int                          @default(5) @map("max_daily_recommendations")
  notificationsEnabled        Boolean                      @default(true) @map("notifications_enabled")
  proactivityLevel            Int                          @default(2) @map("proactivity_level")
  disabledRecommendationTypes DirectorRecommendationType[] @default([]) @map("disabled_recommendation_types")
  createdAt                   DateTime                     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                   DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([organizationId, workspaceId])
  @@map("director_preferences")
}

model RecommendationFeedback {
  id               String                      @id @default(uuid()) @db.Uuid
  organizationId   String                      @map("organization_id") @db.Uuid
  workspaceId      String                      @map("workspace_id") @db.Uuid
  recommendationId String                      @map("recommendation_id") @db.Uuid
  userId           String                      @map("user_id") @db.Uuid
  value            RecommendationFeedbackValue
  reason           String?
  comment          String?
  createdAt        DateTime                    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(3)

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace      Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recommendation DirectorRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, userId])
  @@index([organizationId, workspaceId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("recommendation_feedback")
}
